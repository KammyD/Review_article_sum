---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPages    = await getCollection('pages', ({ data }) => data.meta.published && data.page_type === 'how-to');
const allProducts = await getCollection('products');

const listPage = {
  slug: 'howto-index', page_type: 'how-to', template_style: 'tech', product_ref: null,
  seo: {
    title: '使用教程与操作指南 — 图文详解，新手友好',
    description: '详细的产品使用教程和操作指南，图文并茂，5分钟快速上手，覆盖安装、设置、故障排除等场景。',
    keywords: { primary: '产品使用教程' },
    on_page: { h1: '使用教程与操作指南', h2_list: [], url_slug: 'how-to' },
    schema: { type: 'WebPage' }, canonical: '/how-to',
    og_image: '/images/og/default.png', index: true, follow: true,
  },
  hero: {}, meta: { publish_date: '2025-01-01', author: 'admin', published: true },
};
---

<BaseLayout page={listPage}>
  <section class="list-hero">
    <div class="container">
      <div class="breadcrumb-row"><a href="/">首页</a> <span>/</span> <span>教程</span></div>
      <h1 class="list-h1">使用教程与操作指南</h1>
      <p class="list-sub">图文详解 · 新手友好 · 5分钟快速上手</p>
    </div>
  </section>

  <div class="container">
    <div class="howto-grid">
      {allPages.map(p => {
        const prod = allProducts.find(pr => pr.data.id === p.data.product_ref)?.data;
        return (
          <a href={`/how-to/${p.data.slug}`} class="howto-card">
            <div class="howto-icon">
              {prod?.logo
                ? <img src={prod.logo} alt={prod?.name ?? ''} class="howto-logo" width="48" height="24" />
                : <div class="howto-icon-placeholder">✦</div>
              }
            </div>
            <div class="howto-body">
              <h2 class="howto-title">{p.data.seo.on_page.h1}</h2>
              <p class="howto-desc">{p.data.seo.description.slice(0, 80)}…</p>
            </div>
            <span class="howto-arrow">→</span>
          </a>
        );
      })}
    </div>
    {allPages.length === 0 && (
      <div class="empty-state"><p>暂无教程内容，请先生成页面数据。</p></div>
    )}
  </div>
</BaseLayout>

<style>
.list-hero { background:linear-gradient(135deg,#f5f3ff,#ede9fe); border-bottom:1px solid #ddd6fe; padding:40px 0 32px; }
.breadcrumb-row { display:flex; gap:8px; font-size:13px; color:#7c3aed; margin-bottom:12px; }
.breadcrumb-row a { color:#6d28d9; text-decoration:none; }
.list-h1  { font-size:clamp(1.5rem,3vw,2rem); font-weight:800; margin:0 0 8px; color:#3b0764; }
.list-sub { color:#7c3aed; margin:0; font-size:15px; }
.howto-grid { display:flex; flex-direction:column; gap:12px; padding:40px 0; }
.howto-card { display:flex; align-items:center; gap:16px; padding:18px 22px; border:1px solid #e9d5ff; border-radius:12px; text-decoration:none; color:#111827; background:#fff; transition:box-shadow 0.2s,border-color 0.2s,transform 0.15s; }
.howto-card:hover { box-shadow:0 6px 18px rgba(124,58,237,0.1); border-color:#a855f7; transform:translateX(4px); }
.howto-icon { width:52px; height:52px; border-radius:10px; background:#f5f3ff; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.howto-logo { object-fit:contain; max-height:24px; }
.howto-icon-placeholder { font-size:20px; color:#a855f7; }
.howto-body { flex:1; }
.howto-title { font-size:15px; font-weight:700; margin:0 0 4px; color:#1e1b4b; line-height:1.4; }
.howto-desc  { font-size:13px; color:#6b7280; margin:0; line-height:1.5; }
.howto-arrow { font-size:18px; color:#a855f7; font-weight:700; flex-shrink:0; }
.empty-state { text-align:center; padding:60px 20px; color:#94a3b8; }
</style>
