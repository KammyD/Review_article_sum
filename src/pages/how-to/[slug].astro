---
/**
 * pages/how-to/[slug].astro
 * 问题解决/教程页动态路由
 */
import { getCollection, getEntry } from 'astro:content';

import HowToTech       from '../../layouts/how-to/HowToTech.astro';
import HowToHome       from '../../layouts/how-to/HowToHome.astro';
import HowToFood       from '../../layouts/how-to/HowToFood.astro';
import HowToPet        from '../../layouts/how-to/HowToPet.astro';
import HowToElectronic from '../../layouts/how-to/HowToElectronic.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages', ({ data }) => data.page_type === 'how-to' && data.meta.published);
  return pages.map(page => ({
    params: { slug: page.data.slug },
    props: { pageData: page.data },
  }));
}

const { pageData } = Astro.props;

const productEntry = pageData.product_ref
  ? await getEntry('products', pageData.product_ref)
  : null;

const reviewsEntry = pageData.product_ref
  ? await getEntry('reviews', `${pageData.product_ref}-reviews`).catch(() => null)
  : null;

const allPages = await getCollection('pages', ({ data }) => data.meta.published);

const layoutMap: Record<string, any> = {
  tech:       HowToTech,
  home:       HowToHome,
  food:       HowToFood,
  pet:        HowToPet,
  electronic: HowToElectronic,
};
const Layout = layoutMap[pageData.template_style] ?? HowToTech;

const product = productEntry?.data ?? null;
const reviews = reviewsEntry?.data ?? null;
---
<Layout
  page={pageData}
  product={product}
  reviews={reviews}
  allPages={allPages}
/>
