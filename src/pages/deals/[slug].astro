---
/**
 * pages/deals/[slug].astro
 * 优惠/促销页动态路由
 */
import { getCollection, getEntry } from 'astro:content';

import DealTech       from '../../layouts/deal/DealTech.astro';
import DealHome       from '../../layouts/deal/DealHome.astro';
import DealFood       from '../../layouts/deal/DealFood.astro';
import DealPet        from '../../layouts/deal/DealPet.astro';
import DealElectronic from '../../layouts/deal/DealElectronic.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages', ({ data }) => data.page_type === 'deal' && data.meta.published);
  return pages.map(page => ({
    params: { slug: page.data.slug },
    props: { pageData: page.data },
  }));
}

const { pageData } = Astro.props;

const productEntry = pageData.product_ref
  ? await getEntry('products', pageData.product_ref)
  : null;

const reviewsEntry = pageData.product_ref
  ? await getEntry('reviews', `${pageData.product_ref}-reviews`).catch(() => null)
  : null;

const allPages = await getCollection('pages', ({ data }) => data.meta.published);

const layoutMap: Record<string, any> = {
  tech:       DealTech,
  home:       DealHome,
  food:       DealFood,
  pet:        DealPet,
  electronic: DealElectronic,
};
const Layout = layoutMap[pageData.template_style] ?? DealTech;

const product = productEntry?.data ?? null;
const reviews = reviewsEntry?.data ?? null;
---
<Layout
  page={pageData}
  product={product}
  reviews={reviews}
  allPages={allPages}
/>
