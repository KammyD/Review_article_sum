---
interface FAQ { q: string; a: string; keyword?: string; }
interface Props { faqs: FAQ[]; }
const { faqs } = Astro.props;
---
<div class="faq-list">
  {faqs.map((faq, i) => (
    <div class="faq-item">
      <!-- 第三层 H3：FAQ 必须用问句形式，触发 Google FAQ 富媒体摘要 -->
      <h3 class="faq-q">
        <button
          class="faq-btn"
          aria-expanded="false"
          aria-controls={`faq-a-${i}`}
          onclick={`this.setAttribute('aria-expanded', this.getAttribute('aria-expanded')==='true'?'false':'true');document.getElementById('faq-a-${i}').classList.toggle('open')`}
        >
          {faq.q}
          <span class="faq-icon" aria-hidden="true">+</span>
        </button>
      </h3>
      <div id={`faq-a-${i}`} class="faq-a" role="region">
        <p>{faq.a}</p>
      </div>
    </div>
  ))}
</div>

<style>
.faq-list { border-top: 1px solid var(--border,#e5e7eb); }
.faq-item { border-bottom: 1px solid var(--border,#e5e7eb); }
.faq-q    { margin: 0; font-size: 1rem; }
.faq-btn  {
  width: 100%; display: flex; justify-content: space-between; align-items: center;
  padding: 16px 0; background: none; border: none; cursor: pointer;
  font-size: 1rem; font-weight: 500; color: var(--text,#111827); text-align: left; gap: 12px;
}
.faq-btn:hover { color: var(--accent,#16a34a); }
.faq-icon { font-size: 1.25rem; flex-shrink: 0; transition: transform 0.2s; }
.faq-btn[aria-expanded="true"] .faq-icon { transform: rotate(45deg); }
.faq-a    { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
.faq-a.open { max-height: 600px; }
.faq-a p  { padding: 0 0 16px; margin: 0; color: var(--text-secondary,#4b5563); line-height: 1.7; }
</style>
