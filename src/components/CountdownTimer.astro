---
interface Props { expires?: string; label?: string; }
const { expires, label = '限时优惠结束倒计时' } = Astro.props;
---
<div class="countdown-wrap" data-expires={expires}>
  <span class="countdown-label">{label}</span>
  <div class="countdown-digits">
    <div class="digit-group"><span class="digit" id="cd-h">--</span><span class="digit-label">时</span></div>
    <span class="colon">:</span>
    <div class="digit-group"><span class="digit" id="cd-m">--</span><span class="digit-label">分</span></div>
    <span class="colon">:</span>
    <div class="digit-group"><span class="digit" id="cd-s">--</span><span class="digit-label">秒</span></div>
  </div>
</div>

<script>
(function(){
  const wrap = document.querySelector('.countdown-wrap') as HTMLElement;
  if (!wrap) return;
  const expiresAttr = wrap.dataset.expires;
  let target: Date;
  if (expiresAttr) {
    target = new Date(expiresAttr);
  } else {
    // 默认24小时后
    target = new Date(Date.now() + 24 * 60 * 60 * 1000);
  }
  function update() {
    const diff = target.getTime() - Date.now();
    if (diff <= 0) { wrap.style.display = 'none'; return; }
    const h = Math.floor(diff / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);
    const hEl = document.getElementById('cd-h');
    const mEl = document.getElementById('cd-m');
    const sEl = document.getElementById('cd-s');
    if (hEl) hEl.textContent = String(h).padStart(2,'0');
    if (mEl) mEl.textContent = String(m).padStart(2,'0');
    if (sEl) sEl.textContent = String(s).padStart(2,'0');
  }
  update();
  setInterval(update, 1000);
})();
</script>

<style>
.countdown-wrap  { display:inline-flex; align-items:center; gap:12px; padding:8px 16px; background:#fef9c3; border:1px solid #fde047; border-radius:8px; flex-wrap:wrap; }
.countdown-label { font-size:13px; font-weight:500; color:#854d0e; }
.countdown-digits{ display:flex; align-items:center; gap:4px; }
.digit-group     { display:flex; flex-direction:column; align-items:center; }
.digit           { font-size:22px; font-weight:700; font-variant-numeric:tabular-nums; color:#92400e; min-width:32px; text-align:center; }
.digit-label     { font-size:10px; color:#a16207; }
.colon           { font-size:20px; font-weight:700; color:#a16207; padding-bottom:12px; }
</style>
