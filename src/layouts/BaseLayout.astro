---
/**
 * BaseLayout.astro
 * 最外层 HTML 骨架，所有落地页共用
 */
interface Props {
  page: any;
  product?: any;
  reviews?: any;
  breadcrumbs?: Array<{ name: string; url: string }>;
}
import SEOHead from '../components/SEOHead.astro';
const { page, product, reviews, breadcrumbs } = Astro.props;
const path = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <SEOHead page={page} product={product} reviews={reviews} breadcrumbs={breadcrumbs} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="/" class="site-logo">
        <span class="logo-mark">B</span>
        <span class="logo-text">BestPicks</span>
      </a>
      <nav class="site-nav">
        <a href="/review"  class={path.startsWith('/review')  ? 'active' : ''}>评测</a>
        <a href="/deals"   class={path.startsWith('/deals')   ? 'active' : ''}>优惠</a>
        <a href="/best"    class={path.startsWith('/best')    ? 'active' : ''}>榜单</a>
        <a href="/how-to"  class={path.startsWith('/how-to')  ? 'active' : ''}>教程</a>
        <a href="/brand"   class={path.startsWith('/brand')   ? 'active' : ''}>品牌</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-inner">
        <div class="footer-brand">
          <div class="footer-logo">BestPicks</div>
          <p class="footer-tagline">独立测评 · 真实数据 · 帮你少踩坑</p>
        </div>
        <div class="footer-links">
          <div class="footer-col">
            <div class="footer-col-title">内容</div>
            <a href="/review">产品评测</a>
            <a href="/deals">优惠折扣</a>
            <a href="/best">排行榜单</a>
            <a href="/how-to">使用教程</a>
          </div>
          <div class="footer-col">
            <div class="footer-col-title">关于</div>
            <a href="/about">关于我们</a>
            <a href="/privacy">隐私政策</a>
            <a href="/disclaimer">免责声明</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2025 BestPicks. 保留所有权利。</p>
        <p class="footer-disclaimer">本站部分链接为联盟推广链接，点击购买我们可能获得佣金，不影响您的购买价格，也不影响我们的评测结果。</p>
      </div>
    </div>
  </footer>
</body>
</html>

<style is:global>
*, *::before, *::after { box-sizing: border-box; }
:root {
  --accent: #16a34a;
  --accent-dark: #15803d;
  --text: #111827;
  --text-secondary: #4b5563;
  --border: #e5e7eb;
  --surface: #f9fafb;
  --surface2: #f0fdf4;
  --max-w: 900px;
  --font: 'Segoe UI', system-ui, -apple-system, sans-serif;
}
body { margin:0; font-family:var(--font); color:var(--text); background:#fff; line-height:1.6; }
.container { max-width:var(--max-w); margin:0 auto; padding:0 20px; }
a { color:var(--accent); }
img { max-width:100%; height:auto; }

/* ── Header ── */
.site-header {
  border-bottom:1px solid var(--border); background:#fff;
  position:sticky; top:0; z-index:100;
}
.site-header .container {
  display:flex; align-items:center; justify-content:space-between; height:60px;
}
.site-logo {
  display:flex; align-items:center; gap:8px; text-decoration:none;
}
.logo-mark {
  width:30px; height:30px; border-radius:8px; background:#16a34a;
  color:#fff; display:flex; align-items:center; justify-content:center;
  font-weight:800; font-size:16px; flex-shrink:0;
}
.logo-text { font-weight:800; font-size:17px; color:#0f172a; }
.site-nav { display:flex; gap:4px; }
.site-nav a {
  text-decoration:none; color:#64748b; font-size:14px; font-weight:500;
  padding:6px 12px; border-radius:6px; transition:color 0.15s,background 0.15s;
}
.site-nav a:hover { color:#0f172a; background:#f1f5f9; }
.site-nav a.active { color:#16a34a; background:#f0fdf4; font-weight:600; }

/* ── Footer ── */
.site-footer { border-top:1px solid var(--border); padding:48px 0 32px; margin-top:64px; background:#f8fafc; }
.footer-inner { display:flex; justify-content:space-between; gap:40px; flex-wrap:wrap; margin-bottom:32px; }
.footer-brand { max-width:200px; }
.footer-logo  { font-size:18px; font-weight:800; color:#0f172a; margin-bottom:8px; }
.footer-tagline { font-size:13px; color:#94a3b8; margin:0; line-height:1.6; }
.footer-links { display:flex; gap:48px; }
.footer-col   { display:flex; flex-direction:column; gap:8px; }
.footer-col-title { font-size:12px; font-weight:700; color:#374151; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px; }
.footer-col a { font-size:13px; color:#6b7280; text-decoration:none; }
.footer-col a:hover { color:#16a34a; }
.footer-bottom { border-top:1px solid #e2e8f0; padding-top:20px; }
.footer-bottom p { margin:4px 0; font-size:12px; color:#9ca3af; text-align:center; }
.footer-disclaimer { font-size:11px !important; color:#c4c4c4 !important; }

/* ── Shared sections ── */
.section { padding:40px 0; }
.section-title { font-size:1.5rem; font-weight:700; margin:0 0 20px; color:var(--text); }
.prose { color:var(--text-secondary); line-height:1.8; }
.prose p { margin:0 0 16px; }
.tag { display:inline-block; padding:3px 10px; border-radius:20px; font-size:12px; font-weight:600; }
.tag-green  { background:#dcfce7; color:#15803d; }
.tag-amber  { background:#fef9c3; color:#92400e; }
.tag-blue   { background:#dbeafe; color:#1e40af; }
.tag-red    { background:#fee2e2; color:#991b1b; }
</style>
