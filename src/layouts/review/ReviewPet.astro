---
/**
 * ReviewPet.astro — 评测页 T4：宠物/母婴风
 * 圆润大圆角 + 马卡龙配色 + 安全属性优先
 */
import BaseLayout from '../BaseLayout.astro';
import StarRating from '../../components/StarRating.astro';
import CTAButton from '../../components/CTAButton.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import UserReviews from '../../components/UserReviews.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

interface Props { page: any; product: any; reviews?: any; allPages?: any[]; }
const { page, product, reviews, allPages = [] } = Astro.props;
const aff  = product?.affiliate;
const hero = page.hero ?? {};
const crumbs = [{ name:'首页',url:'/' },{ name:'评测',url:'/review' },{ name:product?.name??page.slug,url:'#' }];
---
<BaseLayout page={page} product={product} reviews={reviews} breadcrumbs={crumbs}>
  <section class="hero-pet">
    <div class="container">
      <Breadcrumb crumbs={crumbs} />
      {hero.badge_text && <span class="pet-badge">{hero.badge_text}</span>}
      <!-- 第一层 H1 -->
      <h1 class="pet-h1">{page.seo.on_page.h1}</h1>
      <p class="pet-sub">{hero.subheadline}</p>
      <div class="pet-score">
        <StarRating score={hero.score ?? product?.ratings?.overall ?? 4.5} size="lg" />
        {hero.verdict && <span class="pet-verdict">{hero.verdict}</span>}
      </div>
      <CTAButton href={aff?.link??'#'} text={hero.cta_primary_text??'立即查看'} affiliateId={aff?.id} position="hero" style="primary" />
    </div>
  </section>
  <div class="container">
    {product?.best_for && (
      <section class="pet-tags section">
        <h2 class="section-title">适合场景</h2>
        <div class="pet-tag-row">{product.best_for.map((b:string)=><span class="pet-tag">{b}</span>)}</div>
      </section>
    )}
    {page.summary_box && (
      <section class="pet-summary section">
        <h2 class="section-title">{page.summary_box.title}</h2>
        <ul>{page.summary_box.points.map((p:string)=><li class="pet-point">{p}</li>)}</ul>
      </section>
    )}
    {page.content_sections?.map((sec:any)=>(
      <section class="section" id={sec.id}>
        <h2 class="section-title">{sec.title}</h2>
        <div class="prose"><p>{sec.body}</p></div>
      </section>
    ))}
    {reviews && (<section class="section"><h2 class="section-title">用户晒单</h2><UserReviews reviews={reviews} /></section>)}
    {page.faqs?.length && (<section class="section"><h2 class="section-title">常见问题</h2><FAQAccordion faqs={page.faqs} /></section>)}
    <section class="pet-cta section">
      <div class="pet-cta-inner">
        <h2>给你的宝贝最好的</h2>
        <CTAButton href={aff?.link??'#'} text={hero.cta_primary_text??'立即购买'} affiliateId={aff?.id} position="end" style="primary" />
        {product?.pricing?.money_back_days && <p class="pet-guarantee">✓ {product.pricing.money_back_days}天退款保证</p>}
      </div>
    </section>
    {page.related_pages?.length && (<section class="section"><h2 class="section-title">相关推荐</h2><RelatedPages relatedSlugs={page.related_pages} allPages={allPages} /></section>)}
  </div>
</BaseLayout>
<style>
.hero-pet { background:#fdf4ff; border-bottom:1px solid #e9d5ff; padding:48px 0 36px; }
.pet-badge { display:inline-block; padding:4px 12px; background:#a855f7; color:#fff; border-radius:20px; font-size:12px; font-weight:600; margin-bottom:12px; }
.pet-h1   { font-size:clamp(1.4rem,3vw,2rem); font-weight:800; color:#581c87; margin:0 0 10px; line-height:1.3; }
.pet-sub  { color:#7e22ce; margin:0 0 14px; }
.pet-score { display:flex; align-items:center; gap:12px; margin-bottom:18px; flex-wrap:wrap; }
.pet-verdict { padding:4px 12px; background:#fae8ff; color:#701a75; border-radius:6px; font-size:13px; font-weight:600; }
.pet-tags  .pet-tag-row { display:flex; flex-wrap:wrap; gap:8px; }
.pet-tag  { padding:6px 14px; background:#fae8ff; color:#7c3aed; border-radius:20px; font-size:13px; font-weight:500; }
.pet-summary { background:#fdf4ff; border:1px solid #e9d5ff; border-radius:16px; padding:24px; }
.pet-point { margin-bottom:10px; color:#6d28d9; }
.pet-cta  { background:#fdf4ff; border-radius:20px; }
.pet-cta-inner { text-align:center; padding:36px 20px; }
.pet-cta-inner h2 { font-size:1.4rem; font-weight:700; color:#581c87; margin:0 0 16px; }
.pet-guarantee { font-size:13px; color:#a855f7; margin-top:10px; }
</style>
