---
/**
 * BrandTech.astro — 品牌专属页 T1：科技/工具风
 * 产品展示台 + 功能矩阵 + 深度品牌内容
 */
import BaseLayout from '../BaseLayout.astro';
import StarRating from '../../components/StarRating.astro';
import CTAButton from '../../components/CTAButton.astro';
import TrustBadges from '../../components/TrustBadges.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import UserReviews from '../../components/UserReviews.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

interface Props { page: any; product: any; reviews?: any; allPages?: any[]; }
const { page, product, reviews, allPages = [] } = Astro.props;
const aff  = product?.affiliate;
const deal = product?.deal;
const hero = page.hero ?? {};
const crumbs = [{ name:'首页',url:'/' },{ name:'品牌',url:'/brand' },{ name:product?.name??page.slug,url:'#' }];
---
<BaseLayout page={page} product={product} reviews={reviews} breadcrumbs={crumbs}>

  <section class="brand-hero">
    <div class="container">
      <Breadcrumb crumbs={crumbs} />
      <div class="brand-hero-inner">
        <div class="brand-hero-left">
          {product?.logo && (
            <img src={product.logo} alt={`${product.name} Logo`} class="brand-logo" width="140" height="60" />
          )}
          <!-- 第一层 H1：品牌名 + 完整指南，覆盖品牌词 -->
          <h1 class="brand-h1">{page.seo.on_page.h1}</h1>
          <p class="brand-sub">{hero.subheadline ?? product?.tagline}</p>
          <div class="brand-ratings">
            {product?.ratings?.overall && (
              <StarRating score={product.ratings.overall} size="lg" />
            )}
            {product?.ratings?.review_count && (
              <span class="brand-review-count">{product.ratings.review_count.toLocaleString()} 条评价</span>
            )}
          </div>
          <div class="brand-ctas">
            <CTAButton href={aff?.link??'#'} text={hero.cta_primary_text??'立即领取优惠'} affiliateId={aff?.id} position="hero" style="primary" />
            <CTAButton href={`/review/${product?.slug}-review`} text={hero.cta_secondary_text??'查看详细评测'} position="hero-review" style="ghost" />
          </div>
          <TrustBadges
            moneyBackDays={product?.pricing?.money_back_days}
            showAudit={product?.features?.no_logs_audited}
            auditor={product?.features?.auditor}
            mediaMentions={page.trust_signals?.media_mentions}
          />
        </div>
        <div class="brand-hero-right">
          <div class="brand-quick-facts">
            <div class="quick-fact"><span class="qf-label">起步价</span><span class="qf-val">${product?.pricing?.starting_from ?? '--'}/月</span></div>
            <div class="quick-fact"><span class="qf-label">免费试用</span><span class="qf-val">{product?.pricing?.has_free_trial ? `${product.pricing.free_trial_days}天` : '无'}</span></div>
            <div class="quick-fact"><span class="qf-label">退款保证</span><span class="qf-val">{product?.pricing?.money_back_days ?? '--'}天</span></div>
            <div class="quick-fact"><span class="qf-label">设备数量</span><span class="qf-val">{product?.features?.simultaneous_devices ?? '--'}台</span></div>
            <div class="quick-fact"><span class="qf-label">成立年份</span><span class="qf-val">{product?.founded_year ?? '--'}年</span></div>
            <div class="quick-fact"><span class="qf-label">总部</span><span class="qf-val">{product?.hq_country ?? '--'}</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="container">

    <!-- ══ 关于品牌内容 ══ -->
    {page.about_sections?.map((sec: any) => (
      <section class="section" id={`about-${sec.title?.toLowerCase().replace(/\s+/g, '-')}`}>
        <h2 class="section-title">{sec.title}</h2>
        {sec.body && <p class="prose">{sec.body}</p>}
        {sec.features && (
          <div class="brand-features">
            {sec.features.map((f: any) => (
              <div class="brand-feature-card">
                <h3 class="bf-name">{f.name}</h3>
                <p class="bf-desc">{f.desc}</p>
              </div>
            ))}
          </div>
        )}
      </section>
    ))}

    <!-- ══ 平台支持 ══ -->
    {product?.platform_support && (
      <section class="section">
        <h2 class="section-title">支持的平台和设备</h2>
        <div class="platform-grid">
          {Object.entries(product.platform_support).filter(([k,v]) => v === true).map(([key]) => (
            <div class="platform-item">✓ {key}</div>
          ))}
        </div>
      </section>
    )}

    <!-- ══ 价格套餐 ══ -->
    {product?.pricing?.plans && (
      <section class="section">
        <h2 class="section-title">价格与套餐方案</h2>
        <div class="brand-plans">
          {product.pricing.plans.map((plan: any) => (
            <div class={`brand-plan ${plan.is_popular ? 'brand-plan-pop' : ''}`}>
              {plan.is_popular && <div class="brand-pop-badge">最受欢迎</div>}
              <div class="bp-name">{plan.name}</div>
              <div class="bp-price">${plan.monthly_price}<small>/月</small></div>
              <ul class="bp-features">{plan.highlights?.map((h:string) => <li>{h}</li>)}</ul>
              <CTAButton href={aff?.link??'#'} text="选择方案" affiliateId={aff?.id} position={`brand-plan-${plan.name}`} style={plan.is_popular ? 'primary':'secondary'} fullWidth={true} />
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- ══ 用户评价 ══ -->
    {reviews && (
      <section class="section">
        <h2 class="section-title">用户真实评价</h2>
        <UserReviews reviews={reviews} />
      </section>
    )}

    {page.faqs?.length && (
      <section class="section">
        <h2 class="section-title">常见问题解答</h2>
        <FAQAccordion faqs={page.faqs} />
      </section>
    )}

    <section class="brand-end-cta section">
      <div class="brand-end-inner">
        <h2>开始使用 {product?.name}</h2>
        {deal?.description && <p>{deal.description}</p>}
        <CTAButton href={aff?.link??'#'} text={hero.cta_primary_text??'立即领取优惠'} affiliateId={aff?.id} position="end" style="primary" />
        {product?.pricing?.money_back_days && <p class="brand-guarantee">✓ {product.pricing.money_back_days}天无理由退款保证</p>}
      </div>
    </section>

    {page.related_pages?.length && (
      <section class="section">
        <h2 class="section-title">相关推荐</h2>
        <RelatedPages relatedSlugs={page.related_pages} allPages={allPages} />
      </section>
    )}
  </div>
</BaseLayout>

<style>
.brand-hero { background:#f8fafc; border-bottom:1px solid var(--border); padding:48px 0 40px; }
.brand-hero-inner { display:grid; grid-template-columns:1.5fr 1fr; gap:40px; align-items:start; }
@media(max-width:640px){ .brand-hero-inner { grid-template-columns:1fr; } }
.brand-logo { margin-bottom:16px; max-height:60px; object-fit:contain; }
.brand-h1   { font-size:clamp(1.4rem,3vw,2rem); font-weight:800; margin:0 0 10px; line-height:1.3; }
.brand-sub  { color:var(--text-secondary); margin:0 0 14px; }
.brand-ratings { display:flex; align-items:center; gap:10px; margin-bottom:18px; flex-wrap:wrap; }
.brand-review-count { font-size:13px; color:var(--text-secondary); }
.brand-ctas { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:16px; }
.brand-quick-facts { background:#fff; border:1px solid var(--border); border-radius:12px; padding:20px; display:grid; grid-template-columns:1fr 1fr; gap:12px; }
.quick-fact { display:flex; flex-direction:column; gap:3px; }
.qf-label   { font-size:11px; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.05em; }
.qf-val     { font-size:15px; font-weight:700; color:var(--text); }
.brand-features { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:12px; margin-top:16px; }
.brand-feature-card { padding:16px; background:var(--surface); border-radius:10px; border-left:3px solid var(--accent); }
.bf-name    { font-size:14px; font-weight:700; margin:0 0 6px; }
.bf-desc    { font-size:13px; color:var(--text-secondary); margin:0; line-height:1.5; }
.platform-grid { display:flex; flex-wrap:wrap; gap:8px; }
.platform-item { padding:6px 14px; background:var(--surface); border:1px solid var(--border); border-radius:6px; font-size:13px; color:var(--text); }
.brand-plans { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:16px; }
.brand-plan { border:1px solid var(--border); border-radius:12px; padding:22px; position:relative; text-align:center; }
.brand-plan-pop { border:2px solid var(--accent); }
.brand-pop-badge { position:absolute; top:-10px; left:50%; transform:translateX(-50%); background:var(--accent); color:#fff; padding:2px 12px; border-radius:20px; font-size:11px; font-weight:600; white-space:nowrap; }
.bp-name    { font-weight:700; margin-bottom:8px; }
.bp-price   { font-size:1.75rem; font-weight:800; color:var(--accent); }
.bp-price small { font-size:13px; color:var(--text-secondary); font-weight:400; }
.bp-features { font-size:13px; margin:10px 0 14px; padding-left:18px; text-align:left; }
.bp-features li { margin-bottom:6px; color:var(--text-secondary); }
.brand-end-cta { background:var(--surface); border-radius:16px; }
.brand-end-inner { text-align:center; padding:40px 20px; }
.brand-end-inner h2 { font-size:1.4rem; font-weight:700; margin:0 0 8px; }
.brand-end-inner p  { color:var(--text-secondary); margin:0 0 20px; }
.brand-guarantee { font-size:13px; color:var(--accent); margin-top:10px; }
</style>
