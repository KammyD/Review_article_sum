      "@type": "Organization",
      "name": "BestPicks",
      "url": "https://www.yoursite.com",
      "logo": "https://www.yoursite.com/images/logo.png"
    },
    "author": {
      "@type": "Person",
      "name": "BestPicks 编辑团队"
    }
  },
  "sitemap": {
    "changefreq_review": "monthly",
