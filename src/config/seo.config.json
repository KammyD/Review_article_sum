{
  "site": {
    "name": "BestPicks",
    "domain": "https://www.yoursite.com",
    "default_locale": "zh-CN",
    "default_og_image": "/images/og/default.png",
    "twitter_handle": "@bestpicks"
  },
  "defaults": {
    "title_suffix": " | BestPicks",
    "title_separator": " - ",
    "meta_robots": "index, follow",
